.header-section {
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  color: #fff;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  border-radius: 0 0 30rpx 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.category-section {
  margin-bottom: 30rpx;
}

.category-scroll {
  white-space: nowrap;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.category-list {
  display: inline-flex;
  padding: 0 16rpx;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
  min-width: 120rpx;
}

.category-item.active {
  background-color: #e3f2fd;
}

.category-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
  white-space: nowrap;
}

.content-section {
  margin-bottom: 30rpx;
}

.category-info {
  margin-bottom: 24rpx;
}

.category-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.tactics-section {
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.title-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.tactics-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tactic-item {
  display: flex;
  align-items: flex-start;
  background-color: #f5f5f5;
  padding: 14rpx 20rpx;
  border-radius: 20rpx;
  max-width: calc(50% - 6rpx);
}

.tactic-dot {
  color: #1a73e8;
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tactic-text {
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
}

.cases-list {
  display: flex;
  flex-direction: column;
}

.case-item {
  margin-bottom: 24rpx;
}

.case-header {
  margin-bottom: 16rpx;
}

.case-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding-left: 20rpx;
  border-left: 6rpx solid #1a73e8;
}

.case-content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.case-signs {
  margin-bottom: 20rpx;
  padding: 16rpx;
  background-color: #fff3e0;
  border-radius: 12rpx;
}

.signs-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #ff9800;
  margin-bottom: 12rpx;
}

.signs-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sign-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 10rpx 16rpx;
  border-radius: 16rpx;
}

.sign-icon {
  font-size: 20rpx;
  margin-right: 8rpx;
}

.sign-text {
  font-size: 22rpx;
  color: #666;
}

.case-tip {
  background-color: #e8f5e9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.tip-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.tip-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tip-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #388e3c;
}

.tip-text {
  font-size: 24rpx;
  color: #2e7d32;
  line-height: 1.5;
}