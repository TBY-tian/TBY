<view class="container">
  <view class="header-section">
    <view class="header-title">骗局百科</view>
    <view class="header-subtitle">了解常见诈骗手法 提高防骗意识</view>
  </view>

  <view class="category-section">
    <scroll-view scroll-x class="category-scroll">
      <view class="category-list">
        <view 
          class="category-item {{currentCategory === item.id ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          bindtap="selectCategory"
          data-id="{{item.id}}"
        >
          <view class="category-icon">{{getIcon(item.icon)}}</view>
          <view class="category-name">{{item.name}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="content-section">
    <view class="category-info card">
      <view class="category-desc">{{currentCategoryDesc}}</view>
    </view>

    <view class="tactics-section card" wx:if="{{currentTactics && currentTactics.length > 0}}">
      <view class="section-title">
        <view class="title-icon">🔍</view>
        <view class="title-text">常见手法</view>
      </view>
      <view class="tactics-list">
        <view class="tactic-item" wx:for="{{currentTactics}}" wx:key="index">
          <view class="tactic-dot">•</view>
          <view class="tactic-text">{{item}}</view>
        </view>
      </view>
    </view>

    <view class="cases-list">
      <view class="case-item card" wx:for="{{currentCases}}" wx:key="title">
        <view class="case-header">
          <view class="case-title">{{item.title}}</view>
        </view>
        <view class="case-content">{{item.content}}</view>
        
        <view class="case-signs" wx:if="{{item.signs && item.signs.length > 0}}">
          <view class="signs-title">识别特征</view>
          <view class="signs-list">
            <view class="sign-item" wx:for="{{item.signs}}" wx:key="index">
              <view class="sign-icon">⚠️</view>
              <view class="sign-text">{{item}}</view>
            </view>
          </view>
        </view>
        
        <view class="case-tip">
          <view class="tip-header">
            <view class="tip-icon">💡</view>
            <view class="tip-label">防骗提示</view>
          </view>
          <view class="tip-text">{{item.tip}}</view>
        </view>
      </view>
    </view>
  </view>
</view>